{
  "name": "nozil-dev",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && NODE_OPTIONS=--dns-result-order=ipv4first astro build",
    "preview": "wrangler dev -c dist/server/wrangler.json --ip 127.0.0.1 --port 8788",
    "deploy": "wrangler deploy -c dist/server/wrangler.json",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.5.4",
    "@astrojs/sitemap": "3.7.2",
    "astro": "6.3.7",
    "resend": "6.12.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@eslint/js": "9.18.0",
    "@playwright/test": "1.49.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.18.0",
    "eslint-plugin-astro": "1.3.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "prettier": "3.4.2",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.20.0",
    "vitest": "2.1.8",
    "wrangler": "4.95.0",
    "zod": "4.4.3"
  }
}
