{
  "name": "nozil-dev",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && NODE_OPTIONS=--dns-result-order=ipv4first astro build",
    "preview": "wrangler dev -c \"$(node scripts/cf-config.mjs)\" --ip 127.0.0.1 --port 8788",
    "deploy": "wrangler deploy -c \"$(node scripts/cf-config.mjs)\"",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.6.0",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "astro": "6.4.2",
    "resend": "6.12.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "astro-pdf": "^1.9.0",
    "eslint": "10.4.1",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "puppeteer": "24.43.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7",
    "wrangler": "4.95.0",
    "zod": "4.4.3"
  }
}
