{
  "name": "nozil.dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "installOhMyZshConfig": true,
      "upgradePackages": true,
      "username": "node"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },
  "mounts": [
    "source=nozil.dev-claude,target=/home/node/.claude,type=volume",
    "source=nozil.dev-gh,target=/home/node/.config/gh,type=volume",
    "source=nozil.dev-rtk,target=/home/node/.local/share/rtk,type=volume",
    "source=nozil.dev-ctx7,target=/home/node/.config/context7,type=volume",
    "source=nozil.dev-wrangler,target=/home/node/.config/.wrangler,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "onCreateCommand": "if [ -w /usr/local/bin ]; then corepack enable; else sudo corepack enable; fi",
  "postStartCommand": "pnpm install",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [4321, 8788],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "openPreview"
    },
    "8788": {
      "label": "Wrangler Pages Dev (CF Functions)",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "cloudflare.cloudflare-workers-bindings",
        "GitHub.vscode-pull-request-github",
        "GitHub.vscode-github-actions",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "tailwindCSS.includeLanguages": {
          "astro": "html"
        },
        "files.associations": {
          "*.astro": "astro",
          "*.css": "tailwindcss"
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
