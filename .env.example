# Build-time env vars (read by `pnpm build` / astro:env). Copy to `.env` for
# local use. Worker *runtime* secrets (RESEND_API_KEY, EMAIL_FROM, EMAIL_TO) go
# in `.dev.vars` instead — see docs/cloudflare.md → Environment Variables.

# Cloudflare Web Analytics site token. Baked into the static HTML beacon at
# build time. Optional: omit it and the build ships no beacon.
# Get it from: CF dashboard → Analytics → Web Analytics → nozil.dev → site token.
CF_BEACON_TOKEN=
