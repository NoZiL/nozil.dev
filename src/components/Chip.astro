---
import { tv } from 'tailwind-variants'
import { pill } from './pill'

// Small static tag used for tech/skill pills on cards, the home page, and
// detail pages. Shares its geometry with FilterChip via the `pill` base.
interface Props {
  size?: 'sm' | 'md'
  class?: string
}

const chip = tv({ extend: pill, base: 'dark:bg-dusk-surface bg-white' })

const { size, class: extra } = Astro.props
---

<li class={chip({ size, class: extra })}>
  <slot />
</li>
