---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import Chip from './Chip.astro'
import { getLang, localizePath, useTranslations } from '../i18n/ui'

interface Props {
  project: CollectionEntry<'projects'>
  // Eager-load + high fetch priority for the first card in a grid (the likely
  // LCP element). Cards further down stay lazy. Defaults to lazy.
  priority?: boolean
}

const { project, priority = false } = Astro.props
const { title, tagline, technologies, categories, image, github, links, type, status } = project.data
const lang = getLang(Astro.currentLocale)
const t = useTranslations(lang)
const href = localizePath(`/portfolio/${project.id}`, lang)

// Two-letter monogram for the thumbnail fallback (handles "nozil.dev" → "NO").
const monogram = title
  .replace(/[^A-Za-z0-9]/g, '')
  .slice(0, 2)
  .toUpperCase()

const categoryLabel = t.project.categoryLabel
const typeLabel = t.project.typeLabel

// Show at most four tech chips on the card; the detail page lists them all.
const techPreview = technologies.slice(0, 4)
const techOverflow = technologies.length - techPreview.length
---

<article
  class="dark:border-dusk-border dark:bg-dusk-surface group flex flex-col overflow-hidden rounded-xl border border-zinc-200 bg-white transition-transform hover:-translate-y-0.5"
>
  <a href={href} class="block" aria-label={`${title} — view project`}>
    {
      image ? (
        <Image
          src={image}
          alt={`${title} screenshot`}
          widths={[400, 512, 768, 1024]}
          sizes="(min-width: 640px) 480px, 100vw"
          format="webp"
          loading={priority ? 'eager' : 'lazy'}
          fetchpriority={priority ? 'high' : 'auto'}
          class="aspect-2/1 w-full object-cover"
        />
      ) : (
        <div
          aria-hidden="true"
          class="from-accent/90 to-accent-dark/70 dark:from-accent-dark/40 dark:to-dusk-bg flex aspect-2/1 w-full items-center justify-center bg-linear-to-br"
        >
          <span class="font-mono text-4xl font-semibold text-white/90">{monogram}</span>
        </div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-semibold text-zinc-900 dark:text-violet-100">
        <a href={href} class="hover:text-accent dark:hover:text-accent-dark">{title}</a>
      </h3>
      <span class="mt-1 flex shrink-0 items-center gap-1.5 font-mono text-xs">
        <span class="text-accent dark:text-accent-dark">{typeLabel[type]}</span>
        {status === 'archived' && <span class="text-zinc-400 dark:text-violet-500">· {t.project.archived}</span>}
      </span>
    </div>
    <p class="mt-2 flex-1 text-sm text-zinc-600 dark:text-violet-300">{tagline}</p>

    {
      techPreview.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {techPreview.map((tech) => (
            <Chip>{tech}</Chip>
          ))}
          {techOverflow > 0 && <Chip class="text-zinc-400 dark:text-violet-500">+{techOverflow}</Chip>}
        </ul>
      )
    }

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1">
      {
        categories.map((c) => (
          <span class="text-accent dark:text-accent-dark font-mono text-xs">{categoryLabel[c]}</span>
        ))
      }
      <span class="flex-1"></span>
      {
        links.map((l) => (
          <a
            href={l.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent dark:hover:text-accent-dark font-mono text-xs text-zinc-500 dark:text-violet-400"
          >
            {l.label}
          </a>
        ))
      }
      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent dark:hover:text-accent-dark font-mono text-xs text-zinc-500 dark:text-violet-400"
          >
            GitHub
          </a>
        )
      }
    </div>
  </div>
</article>
