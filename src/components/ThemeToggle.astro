{
  /* Dark mode toggle. Initial state is set before first paint by the no-flash
    script in BaseLayout; this only handles the click. */
}
<button
  type="button"
  id="theme-toggle"
  class="hover:text-accent dark:hover:text-accent-dark -m-2 cursor-pointer p-2"
  aria-label="Toggle dark mode"
  aria-pressed="false"
>
  {/* Moon — shown in light mode */}
  <svg
    class="size-4 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  {/* Sun — shown in dark mode */}
  <svg
    class="hidden size-4 dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle')
  const syncPressed = () =>
    toggle?.setAttribute('aria-pressed', String(document.documentElement.classList.contains('dark')))
  syncPressed()
  toggle?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', dark ? 'dark' : 'light')
    syncPressed()
  })
</script>
