---
// Renders a JSON-LD structured-data block. `application/ld+json` scripts are
// left untouched by Astro's bundler, but is:inline makes that explicit.
interface Props {
  schema: Record<string, unknown>
}
const { schema } = Astro.props
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
