---
import PageLayout from '../../layouts/PageLayout.astro'
import SectionHeading from '../SectionHeading.astro'
import EmailReveal from '../EmailReveal.astro'
import { getLang, useTranslations } from '../../i18n/ui'

const t = useTranslations(getLang(Astro.currentLocale))
---

<PageLayout title={t.contact.title} description={t.contact.metaDescription}>
  <SectionHeading>{t.contact.heading}</SectionHeading>
  <p class="mt-2 max-w-prose text-zinc-600 dark:text-violet-300">
    {t.contact.intro}
  </p>

  <div id="form-wrap" class="mt-8">
    <form
      id="contact-form"
      novalidate
      class="max-w-lg space-y-5"
      data-msg-name={t.contact.errors.name}
      data-msg-email={t.contact.errors.email}
      data-msg-message={t.contact.errors.message}
      data-label-send={t.contact.send}
      data-label-sending={t.contact.sending}
    >
      <div>
        <label for="name" class="block text-sm font-medium text-zinc-900 dark:text-violet-100">{t.contact.name}</label>
        <input
          type="text"
          id="name"
          name="name"
          autocomplete="name"
          required
          class="dark:border-dusk-border dark:bg-dusk-surface mt-1 block min-h-11 w-full rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-violet-600 dark:text-violet-100 dark:placeholder-violet-500 dark:focus:ring-violet-400"
        />
        <p id="error-name" class="mt-1 text-sm text-red-600 dark:text-red-400" hidden></p>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-zinc-900 dark:text-violet-100">{t.contact.email}</label
        >
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          class="dark:border-dusk-border dark:bg-dusk-surface mt-1 block min-h-11 w-full rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-violet-600 dark:text-violet-100 dark:placeholder-violet-500 dark:focus:ring-violet-400"
        />
        <p id="error-email" class="mt-1 text-sm text-red-600 dark:text-red-400" hidden></p>
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium text-zinc-900 dark:text-violet-100">
          {t.contact.subject}
          <span class="font-normal text-zinc-400 dark:text-violet-500">{t.contact.optional}</span>
        </label>
        <select
          id="subject"
          name="subject"
          class="dark:border-dusk-border dark:bg-dusk-surface mt-1 block min-h-11 w-full rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-zinc-900 focus:outline-none focus:ring-2 focus:ring-violet-600 dark:text-violet-100 dark:focus:ring-violet-400"
        >
          <option value="">{t.contact.selectTopic}</option>
          <option value="Freelance inquiry">{t.contact.topics.freelance}</option>
          <option value="Just saying hi">{t.contact.topics.hi}</option>
          <option value="Other">{t.contact.topics.other}</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-zinc-900 dark:text-violet-100"
          >{t.contact.message}</label
        >
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="dark:border-dusk-border dark:bg-dusk-surface mt-1 block w-full resize-y rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-violet-600 dark:text-violet-100 dark:placeholder-violet-500 dark:focus:ring-violet-400"
        ></textarea>
        <p id="error-message" class="mt-1 text-sm text-red-600 dark:text-red-400" hidden></p>
      </div>

      {/* Honeypot — bots fill this, humans never see it */}
      <div class="hidden" aria-hidden="true">
        <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="min-h-11 rounded-lg bg-violet-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-violet-700 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-violet-400 dark:text-violet-950 dark:hover:bg-violet-300"
      >
        {t.contact.send}
      </button>
    </form>

    {/* Outside the form so it doesn't participate in form submission */}
    <div
      id="server-error"
      hidden
      role="alert"
      class="mt-5 max-w-lg rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-900 dark:bg-red-950"
    >
      <p class="text-sm text-red-700 dark:text-red-300">{t.contact.serverError}</p>
      <div class="mt-2 text-sm">
        <EmailReveal suffix="contact" />
      </div>
    </div>
  </div>

  <div id="success-wrap" class="mt-8" hidden>
    <div class="max-w-lg rounded-lg border border-green-200 bg-green-50 p-6 dark:border-green-900 dark:bg-green-950">
      <p class="font-medium text-green-800 dark:text-green-100">{t.contact.successTitle}</p>
      <p class="mt-1 text-sm text-green-700 dark:text-green-300">{t.contact.successBody}</p>
    </div>
  </div>

  <p class="mt-8 text-sm text-zinc-400 dark:text-violet-500">{t.contact.privacy}</p>
</PageLayout>

<script>
  type Status = 'idle' | 'submitting' | 'success' | 'error'
  type State = { status: Status; errors: Record<string, string> }

  const els = {
    form: document.getElementById('contact-form') as HTMLFormElement,
    formWrap: document.getElementById('form-wrap') as HTMLElement,
    successWrap: document.getElementById('success-wrap') as HTMLElement,
    serverError: document.getElementById('server-error') as HTMLElement,
    submitBtn: document.getElementById('submit-btn') as HTMLButtonElement,
  }

  // Localized copy comes from data-* attributes set server-side, so the script
  // stays locale-agnostic (no duplicated en/fr bundles).
  const msg = {
    name: els.form.dataset.msgName ?? 'Name is required',
    email: els.form.dataset.msgEmail ?? 'A valid email is required',
    message: els.form.dataset.msgMessage ?? 'Message must be at least 20 characters',
    send: els.form.dataset.labelSend ?? 'Send message',
    sending: els.form.dataset.labelSending ?? 'Sending…',
  }

  // Every per-field error slot in the form (id="error-<field>").
  const errorSlots = new Map<string, HTMLElement>(
    [...els.form.querySelectorAll<HTMLElement>('[id^="error-"]')].map((el) => [el.id.replace('error-', ''), el])
  )

  function render(state: State) {
    els.formWrap.hidden = state.status === 'success'
    els.successWrap.hidden = state.status !== 'success'
    els.serverError.hidden = state.status !== 'error'
    els.submitBtn.disabled = state.status === 'submitting'
    els.submitBtn.textContent = state.status === 'submitting' ? msg.sending : msg.send

    // Drive every error slot from state — fields the server flags but the
    // client doesn't validate (e.g. subject) still surface.
    for (const [field, el] of errorSlots) {
      const m = state.errors[field]
      el.hidden = !m
      el.textContent = m ?? ''
    }
  }

  let state: State = { status: 'idle', errors: {} }
  render(state)

  els.form.addEventListener('submit', async (e) => {
    e.preventDefault()

    const fd = new FormData(els.form)
    const name = ((fd.get('name') as string) ?? '').trim()
    const email = ((fd.get('email') as string) ?? '').trim()
    const subject = ((fd.get('subject') as string) ?? '').trim()
    const message = ((fd.get('message') as string) ?? '').trim()
    const _honey = (fd.get('_honey') as string) ?? ''

    const errors: Record<string, string> = {}
    if (!name) errors.name = msg.name
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.email = msg.email
    if (message.length < 20) errors.message = msg.message

    if (Object.keys(errors).length > 0) {
      state = { status: 'idle', errors }
      render(state)
      return
    }

    state = { status: 'submitting', errors: {} }
    render(state)

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, subject: subject || undefined, message, _honey }),
      })

      if (res.ok) {
        state = { status: 'success', errors: {} }
        render(state)
        return
      }

      type ErrorBody = { error?: string; issues?: Record<string, string[]> }
      const data = (await res.json()) as ErrorBody
      // Route each issue to its field slot; any field without a slot (or a
      // non-field error) falls through to the generic server-error block.
      const fieldErrors: Record<string, string> = {}
      let hasUnslottedError = false
      for (const [field, msgs] of Object.entries(data.issues ?? {})) {
        if (errorSlots.has(field)) fieldErrors[field] = msgs[0] ?? 'Invalid value'
        else hasUnslottedError = true
      }
      const hasFieldErrors = Object.keys(fieldErrors).length > 0
      state = {
        status: hasFieldErrors && !hasUnslottedError ? 'idle' : 'error',
        errors: fieldErrors,
      }
    } catch {
      state = { status: 'error', errors: {} }
    }

    render(state)
  })
</script>
