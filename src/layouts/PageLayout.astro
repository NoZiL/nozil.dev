---
import BaseLayout from './BaseLayout.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import LangToggle from '../components/LangToggle.astro'
import EmailReveal from '../components/EmailReveal.astro'
import JsonLd from '../components/JsonLd.astro'
import { getLang, localizePath, stripLocale, useTranslations } from '../i18n/ui'

interface Crumb {
  name: string
  url: string
}

interface Props {
  title: string
  description?: string
  ogImage?: string
  // Override the breadcrumb trail (e.g. a project's real title on a detail
  // page). Defaults to one derived from the URL path segments.
  breadcrumbs?: Crumb[]
}

const { title, description, ogImage, breadcrumbs } = Astro.props

const lang = getLang(Astro.currentLocale)
const t = useTranslations(lang)

// BreadcrumbList JSON-LD on every page (issue #8). Derive a trail from the
// locale-stripped path when none is passed: "/fr/portfolio/foo" → Home ›
// Portfolio › Foo, with each crumb URL localized back to the current locale.
const segments = stripLocale(Astro.url.pathname).split('/').filter(Boolean)
const titleCase = (s: string) => s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())
const trail: Crumb[] = breadcrumbs ?? [
  { name: 'Home', url: '/' },
  ...segments.map((seg, i) => ({ name: titleCase(seg), url: `/${segments.slice(0, i + 1).join('/')}` })),
]
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: trail.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: new URL(localizePath(crumb.url, lang), Astro.site).href,
  })),
}
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <JsonLd schema={breadcrumbSchema} />
  <div class="mx-auto flex min-h-screen max-w-3xl flex-col px-6">
    <header class="flex items-center justify-between gap-2 py-6" data-print-hide>
      <a
        href={localizePath('/', lang)}
        class="flex shrink-0 items-center gap-2 text-zinc-900 dark:text-violet-100"
        aria-label="nozil.dev — home"
      >
        {/* Z mark: glyph follows currentColor (theme-adaptive), caret stays brand cyan */}
        <svg viewBox="14 14 78 72" class="h-5 w-auto" aria-hidden="true">
          <rect x="14" y="14" width="60" height="17" fill="currentColor"></rect>
          <rect x="14" y="69" width="60" height="17" fill="currentColor"></rect>
          <polygon points="56,31 74,31 32,69 14,69" fill="currentColor"></polygon>
          <rect x="79" y="69" width="13" height="17" fill="#22D3EE"></rect>
        </svg>
        {/* Wordmark drops below sm — the icon mark + aria-label carry the home link on narrow viewports */}
        <span class="hidden font-mono text-sm font-medium sm:inline"
          >nozil<span class="text-accent dark:text-accent-dark">.dev</span></span
        >
      </a>
      <nav class="flex min-w-0 items-center gap-1.5 text-sm sm:gap-4" aria-label="Main">
        <a href={localizePath('/work', lang)} class="hover:text-accent dark:hover:text-accent-dark shrink-0"
          >{t.nav.work}</a
        >
        <a href={localizePath('/portfolio', lang)} class="hover:text-accent dark:hover:text-accent-dark shrink-0"
          >{t.nav.portfolio}</a
        >
        <a href={localizePath('/contact', lang)} class="hover:text-accent dark:hover:text-accent-dark shrink-0"
          >{t.nav.contact}</a
        >
        <ThemeToggle />
        <LangToggle />
        {/* Icon-only below sm (matches ThemeToggle's collapse pattern); full label from sm up */}
        <a
          href="https://www.malt.fr/profile/nicolaszilli"
          class="bg-accent dark:bg-accent-dark dark:text-dusk-bg flex size-8 shrink-0 items-center justify-center rounded-full text-white hover:opacity-90 sm:size-auto sm:px-3 sm:py-1.5"
          aria-label={t.nav.hireMe}
        >
          <svg
            class="size-4 sm:hidden"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="3" y="7" width="18" height="13" rx="2"></rect>
            <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            <line x1="3" y1="13" x2="21" y2="13"></line>
          </svg>
          <span class="hidden text-xs font-medium whitespace-nowrap sm:inline">{t.nav.hireMe}</span>
        </a>
      </nav>
    </header>
    <main class="flex-1 py-8">
      <slot />
    </main>
    <footer
      class="dark:border-dusk-border space-y-3 border-t border-zinc-200 py-8 text-sm text-zinc-400 dark:text-violet-500"
      data-print-hide
    >
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <a href="https://github.com/nozil" class="hover:text-accent dark:hover:text-accent-dark">GitHub</a>
        <a href="https://www.linkedin.com/in/nicolaszilli" class="hover:text-accent dark:hover:text-accent-dark"
          >LinkedIn</a
        >
        <a href="https://www.malt.fr/profile/nicolaszilli" class="hover:text-accent dark:hover:text-accent-dark">Malt</a
        >
        <a href="https://hashnode.com/@nozil" class="hover:text-accent dark:hover:text-accent-dark">Hashnode</a>
        <a href="https://dev.to/nozil" class="hover:text-accent dark:hover:text-accent-dark">dev.to</a>
        <EmailReveal />
      </div>
      <p>
        {t.footer.builtWith}
        <a href="https://astro.build" class="hover:text-accent dark:hover:text-accent-dark">Astro</a>
        {t.footer.and}
        <a href="https://workers.cloudflare.com" class="hover:text-accent dark:hover:text-accent-dark">Cloudflare</a>.
      </p>
    </footer>
  </div>
</BaseLayout>
