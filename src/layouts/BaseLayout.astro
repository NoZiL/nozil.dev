---
import '../styles/global.css'
import { CF_BEACON_TOKEN } from 'astro:env/client'
import { getLang, localizePath, stripLocale } from '../i18n/ui'

interface Props {
  title: string
  description?: string
  // Path under public/ (e.g. /projects/foo.png) or absolute URL, resolved to an
  // absolute og:image. Omit to skip the tag.
  ogImage?: string
}

const {
  title,
  description = 'Lead Mobile Engineer at Tennaxia · Freelance dev at nozil.dev · React Native & TypeScript · Lyon, France',
  ogImage,
} = Astro.props
const lang = getLang(Astro.currentLocale)
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined

// hreflang alternates (issue #7) — the same content path in each locale, plus
// x-default → en. Derived from the canonical (locale-stripped) path so it works
// on every page without per-page wiring.
const shared = stripLocale(Astro.url.pathname)
const alternates = [
  { hreflang: 'en', href: new URL(localizePath(shared, 'en'), Astro.site).href },
  { hreflang: 'fr', href: new URL(localizePath(shared, 'fr'), Astro.site).href },
  { hreflang: 'x-default', href: new URL(localizePath(shared, 'en'), Astro.site).href },
]
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {/* Identity verification (IndieAuth / Mastodon-style) */}
    <link rel="me" href="https://github.com/nozil" />
    <link rel="me" href="https://www.linkedin.com/in/nicolaszilli" />
    {/* No-flash dark mode: runs before first paint */}
    <script is:inline>
      ;(() => {
        const stored = localStorage.getItem('theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body class="min-h-screen font-sans antialiased">
    <slot />
    {
      /*
      Cloudflare Web Analytics — cookieless, no PII, no consent banner needed.
      Manual beacon: CF's "automatic setup" does not inject on Worker-served
      responses, only on proxied origins/Pages. Token comes from the build-time
      CF_BEACON_TOKEN env var (see astro.config.mjs); omitted when unset so
      local/PR builds carry no beacon. is:inline keeps the data-cf-beacon
      attribute verbatim instead of letting Astro process the script.
    */
    }
    {
      CF_BEACON_TOKEN && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: CF_BEACON_TOKEN })}
        />
      )
    }
  </body>
</html>
