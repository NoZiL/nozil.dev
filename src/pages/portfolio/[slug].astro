---
import { getCollection, render } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import PageLayout from '../../layouts/PageLayout.astro'
import Chip from '../../components/Chip.astro'
import ButtonLink from '../../components/ButtonLink.astro'
import SectionHeading from '../../components/SectionHeading.astro'

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects')
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }))
}) satisfies GetStaticPaths

const { project } = Astro.props
const {
  title,
  tagline,
  technologies,
  categories,
  image,
  github,
  links,
  role,
  client,
  type,
  status,
  startDate,
  endDate,
} = project.data
const { Content } = await render(project)

const monogram = title
  .replace(/[^A-Za-z0-9]/g, '')
  .slice(0, 2)
  .toUpperCase()

const fmt = (d: Date) => d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })
const dateRange = `${fmt(startDate)} — ${endDate ? fmt(endDate) : 'Ongoing'}`

const categoryLabel: Record<string, string> = { mobile: 'Mobile', web: 'Web', oss: 'OSS' }
const typeLabel: Record<string, string> = { work: 'Work', oss: 'OSS', personal: 'Personal' }

// Explicit breadcrumb trail so the last crumb uses the project's real title
// rather than the title-cased slug (issue #8 — BreadcrumbList on all pages).
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portfolio', url: '/portfolio' },
  { name: title, url: `/portfolio/${project.id}` },
]
---

<PageLayout title={`${title} — Nicolas Zilli`} description={tagline} ogImage={image} breadcrumbs={breadcrumbs}>
  <a
    href="/portfolio"
    class="hover:text-accent dark:hover:text-accent-dark font-mono text-xs text-zinc-400 dark:text-violet-500"
  >
    ← Portfolio
  </a>

  {
    image ? (
      <img
        src={image}
        alt={`${title} screenshot`}
        width="1024"
        height="512"
        class="dark:border-dusk-border mt-4 aspect-2/1 w-full rounded-xl border border-zinc-200 object-cover"
      />
    ) : (
      <div
        aria-hidden="true"
        class="from-accent/90 to-accent-dark/70 dark:from-accent-dark/40 dark:to-dusk-bg mt-4 flex aspect-2/1 w-full items-center justify-center rounded-xl bg-linear-to-br"
      >
        <span class="font-mono text-6xl font-semibold text-white/90">{monogram}</span>
      </div>
    )
  }

  <section class="mt-8">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      {
        categories.map((c) => (
          <span class="text-accent dark:text-accent-dark font-mono text-xs">{categoryLabel[c]}</span>
        ))
      }
      <span class="text-accent dark:text-accent-dark font-mono text-xs">· {typeLabel[type]}</span>
      {status === 'archived' && <span class="font-mono text-xs text-zinc-400 dark:text-violet-500">· Archived</span>}
    </div>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-900 md:text-4xl dark:text-violet-100">{title}</h1>
    <p class="mt-3 max-w-prose text-lg text-zinc-600 dark:text-violet-300">{tagline}</p>

    <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-2">
      <div>
        <dt class="font-mono text-xs text-zinc-400 dark:text-violet-500">Role</dt>
        <dd class="text-sm text-zinc-900 dark:text-violet-100">{role}</dd>
      </div>
      {
        client && (
          <div>
            <dt class="font-mono text-xs text-zinc-400 dark:text-violet-500">Context</dt>
            <dd class="text-sm text-zinc-900 dark:text-violet-100">{client}</dd>
          </div>
        )
      }
      <div>
        <dt class="font-mono text-xs text-zinc-400 dark:text-violet-500">When</dt>
        <dd class="text-sm text-zinc-900 dark:text-violet-100">{dateRange}</dd>
      </div>
    </dl>

    {
      (links.length > 0 || github) && (
        <div class="mt-6 flex flex-wrap gap-3">
          {links.map((l, i) => (
            <ButtonLink
              href={l.url}
              variant={i === 0 ? 'primary' : 'outline'}
              target="_blank"
              rel="noopener noreferrer"
            >
              {l.label}
            </ButtonLink>
          ))}
          {github && (
            <ButtonLink
              href={github}
              variant={links.length === 0 ? 'primary' : 'outline'}
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </ButtonLink>
          )}
        </div>
      )
    }
  </section>

  <div class="prose prose-zinc dark:prose-invert mt-10 max-w-none">
    <Content />
  </div>

  {
    technologies.length > 0 && (
      <section class="mt-10">
        <SectionHeading>Tech stack</SectionHeading>
        <ul class="mt-4 flex flex-wrap gap-2">
          {technologies.map((tech) => (
            <Chip size="md">{tech}</Chip>
          ))}
        </ul>
      </section>
    )
  }
</PageLayout>
