---
import type { GetStaticPaths } from 'astro'
import ProjectBody from '../../../components/pages/ProjectBody.astro'
import { entrySlug, getLocalizedEntries } from '../../../i18n/content'

// French detail pages. Same slugs as the English route; getLocalizedEntries
// falls back to the English entry for any project not yet translated, so every
// slug resolves in both locales and the hreflang alternates line up.
export const getStaticPaths = (async () => {
  const projects = await getLocalizedEntries('projects', 'fr')
  return projects.map((project) => ({ params: { slug: entrySlug(project.id) }, props: { project } }))
}) satisfies GetStaticPaths

const { project } = Astro.props
---

<ProjectBody project={project} />
