---
import PageLayout from '../layouts/PageLayout.astro'
import { getCollection, render } from 'astro:content'

const roles = (await getCollection('work')).sort((a, b) => {
  // Current roles (null / undefined endDate) float to the top
  if (!a.data.endDate && b.data.endDate) return -1
  if (a.data.endDate && !b.data.endDate) return 1
  return b.data.startDate.getTime() - a.data.startDate.getTime()
})

const renderedRoles = await Promise.all(roles.map(async (role) => ({ role, Content: (await render(role)).Content })))

function fmt(date: Date) {
  return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })
}

const skillGroups = [
  { name: 'Mobile', skills: ['React Native', 'Expo', 'EAS Build / EAS Submit'] },
  { name: 'Frontend', skills: ['React', 'TypeScript', 'Tailwind CSS', 'Astro', 'Next.js'] },
  { name: 'Backend / API', skills: ['Node.js', 'GraphQL', 'REST', 'PostgreSQL', 'Elixir / Phoenix'] },
  { name: 'DevOps & Tooling', skills: ['GitHub Actions', 'Turborepo', 'pnpm', 'Docker', 'Cloudflare Workers'] },
]

const typeLabel: Record<string, string> = {
  'full-time': 'Full-time',
  freelance: 'Freelance',
  contract: 'Contract',
  'open-source': 'Open source',
}

const chip =
  'dark:border-dusk-border dark:bg-dusk-surface rounded-full border border-zinc-200 bg-white px-3 py-1 font-mono text-xs'
---

<PageLayout title="Nicolas Zilli — Work & CV">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 md:text-4xl dark:text-violet-100">Work & CV</h1>
      <p class="mt-1 text-sm text-zinc-400 dark:text-violet-500">Full timeline · Lyon, France</p>
    </div>
    <a
      href="/cv.pdf"
      download
      class="dark:border-dusk-border hover:border-accent hover:text-accent dark:hover:border-accent-dark dark:hover:text-accent-dark mt-1 rounded-lg border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-900 dark:text-violet-100"
    >
      ↓ Download CV
    </a>
  </div>

  <section class="mt-12" aria-labelledby="experience-heading">
    <h2
      id="experience-heading"
      class="mb-8 text-sm font-medium tracking-wide text-zinc-400 uppercase dark:text-violet-500"
    >
      Experience
    </h2>

    <ol class="space-y-12" aria-label="Work history">
      {
        renderedRoles.map(({ role, Content }) => (
          <li>
            <article>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <div>
                  <h3 class="text-lg font-semibold text-zinc-900 dark:text-violet-100">{role.data.title}</h3>
                  <p class="mt-0.5 text-sm">
                    {role.data.companyUrl ? (
                      <a
                        href={role.data.companyUrl}
                        class="text-accent dark:text-accent-dark hover:underline"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {role.data.company}
                      </a>
                    ) : (
                      <span class="text-accent dark:text-accent-dark">{role.data.company}</span>
                    )}
                    <span class="text-zinc-400 dark:text-violet-500"> · {role.data.location}</span>
                  </p>
                </div>
                <div class="flex shrink-0 items-center gap-2 sm:flex-col sm:items-end">
                  <span class="text-sm text-zinc-400 dark:text-violet-500">
                    {fmt(role.data.startDate)} — {role.data.endDate ? fmt(role.data.endDate) : 'Present'}
                  </span>
                  <span class="dark:border-dusk-border rounded-full border border-zinc-200 px-2 py-0.5 font-mono text-xs text-zinc-400 dark:text-violet-500">
                    {typeLabel[role.data.type]}
                  </span>
                </div>
              </div>

              <div class="prose prose-sm dark:prose-invert mt-4 max-w-none text-zinc-600 dark:text-violet-300">
                <Content />
              </div>

              <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
                {role.data.technologies.map((tech) => (
                  <li class={chip}>{tech}</li>
                ))}
              </ul>
            </article>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="mt-16" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="mb-8 text-sm font-medium tracking-wide text-zinc-400 uppercase dark:text-violet-500">
      Skills
    </h2>

    <div class="space-y-6">
      {
        skillGroups.map((group) => (
          <div>
            <h3 class="mb-3 text-xs font-medium tracking-wider text-zinc-400 uppercase dark:text-violet-500">
              {group.name}
            </h3>
            <ul class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <li class={chip}>{skill}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-16" aria-labelledby="education-heading">
    <h2
      id="education-heading"
      class="mb-8 text-sm font-medium tracking-wide text-zinc-400 uppercase dark:text-violet-500"
    >
      Education
    </h2>
    <!-- Fill in your real education details here -->
    <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between">
      <div>
        <p class="font-medium text-zinc-900 dark:text-violet-100">BTS Informatique de Gestion</p>
        <p class="text-sm text-zinc-400 dark:text-violet-500">Lycée technique · Lyon, France</p>
      </div>
      <span class="text-sm text-zinc-400 dark:text-violet-500">2014</span>
    </div>
  </section>
</PageLayout>
