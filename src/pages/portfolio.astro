---
import { getCollection } from 'astro:content'
import PageLayout from '../layouts/PageLayout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import FilterChip from '../components/FilterChip.astro'
import JsonLd from '../components/JsonLd.astro'

// Featured first, then most recent (ongoing roles — no endDate — float up),
// then by start date. `order` breaks ties among featured.
const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1
  if (a.data.featured && b.data.featured && a.data.order !== b.data.order) return a.data.order - b.data.order
  const aEnd = a.data.endDate?.getTime() ?? Infinity
  const bEnd = b.data.endDate?.getTime() ?? Infinity
  if (aEnd !== bEnd) return bEnd - aEnd
  return b.data.startDate.getTime() - a.data.startDate.getTime()
})

const filters = [
  { id: 'all', label: 'All' },
  { id: 'mobile', label: 'Mobile' },
  { id: 'web', label: 'Web' },
  { id: 'oss', label: 'OSS' },
] as const

// JSON-LD ItemList schema (issue #8) — orders the portfolio entries so search
// engines and LLMs see the curated list and can crawl each detail page.
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Portfolio — Nicolas Zilli',
  itemListElement: projects.map((project, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: project.data.title,
    url: new URL(`/portfolio/${project.id}`, Astro.site).href,
  })),
}
---

<PageLayout
  title="Portfolio — Nicolas Zilli"
  description="Selected projects by Nicolas Zilli — mobile apps, web platforms, and open-source work."
>
  <JsonLd schema={itemListSchema} />
  <section>
    <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 md:text-4xl dark:text-violet-100">Portfolio</h1>
    <p class="mt-4 max-w-prose text-lg">
      A few projects that show the work — shipped mobile apps, an open-source public service, and the things I build for
      myself.
    </p>
  </section>

  <section class="mt-8" aria-label="Filter projects">
    <ul class="flex flex-wrap gap-2" role="group" aria-label="Filter by category">
      {
        filters.map((f, i) => (
          <li>
            <FilterChip filter={f.id} pressed={i === 0}>
              {f.label}
            </FilterChip>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-8" aria-label="Projects">
    <ul id="project-grid" class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {
        projects.map((project) => (
          <li data-categories={project.data.categories.join(' ')}>
            <ProjectCard project={project} />
          </li>
        ))
      }
    </ul>
    <p id="no-results" hidden class="mt-4 text-sm text-zinc-400 dark:text-violet-500">
      No projects in this category yet.
    </p>
  </section>
</PageLayout>

<script>
  // Client-side category filter — no reload. Toggles list-item visibility by
  // matching the chip's data-filter against each card's data-categories.
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'))
  const items = Array.from(document.querySelectorAll<HTMLLIElement>('#project-grid > li'))
  const noResults = document.getElementById('no-results')

  function apply(filter: string) {
    let visible = 0
    for (const item of items) {
      const cats = (item.dataset.categories ?? '').split(' ').filter(Boolean)
      const show = filter === 'all' || cats.includes(filter)
      item.hidden = !show
      if (show) visible++
    }
    if (noResults) noResults.hidden = visible !== 0
    for (const b of buttons) b.setAttribute('aria-pressed', String(b.dataset.filter === filter))
  }

  for (const b of buttons) {
    b.addEventListener('click', () => apply(b.dataset.filter ?? 'all'))
  }
</script>
